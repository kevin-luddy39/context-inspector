    "ai-diagnostics",
    "claude",
    "openai",
    "agent"
  ],
  "author": "Kevin Luddy <kevin.luddy39@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevin-luddy39/context-inspector.git"
  },
  "homepage": "https://github.com/kevin-luddy39/context-inspector#readme",
  "bugs": {
    "url": "https://github.com/kevin-luddy39/context-inspector/issues"
  },
  "main": "src/index.js",
  "module": "src/smithery/index.ts",
  "bin": {
